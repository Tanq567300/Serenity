{
  "version": 2,
  "builds": [
    {
      "src": "frontend/vite.config.js",
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    {
      "src": "backend/api/chat.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/chat", "destination": "/backend/api/chat.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

